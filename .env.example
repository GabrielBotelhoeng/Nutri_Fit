# NutriChat — variaveis para docker-compose.local.yml
# Copie para .env e preencha com seus valores

# Supabase (obrigatorio mesmo em dev — banco local e apenas para N8N/Evolution)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Evolution API
EVOLUTION_API_KEY=nutrichat_local_key
# SEC-2: secret unico (32+ bytes hex) usado no header `X-Webhook-Secret`
# que a Evolution envia ao backend. Gerar com `openssl rand -hex 32`.
EVOLUTION_WEBHOOK_SECRET=

# N8N
N8N_WEBHOOK_URL=http://localhost:5678
N8N_BASIC_AUTH_PASSWORD=nutrichat123

# APIs externas
CLAUDE_API_KEY=
GROQ_API_KEY=
