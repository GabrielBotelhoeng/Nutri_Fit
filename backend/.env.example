# NutriChat Backend — variaveis de ambiente
# Copie para .env e preencha com seus valores reais

PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=

# N8N
N8N_WEBHOOK_URL=http://localhost:5678

# Anthropic (Claude)
CLAUDE_API_KEY=

# Groq (Whisper)
GROQ_API_KEY=

# OpenAI (Embeddings RAG)
OPENAI_API_KEY=your-openai-api-key-here

# Chave interna para proteger endpoints administrativos (boas-vindas, rag/processar)
INTERNAL_API_KEY=your-internal-api-key-here

# Fuso horario do "dia nutricional" dos pacientes (opcional, default America/Sao_Paulo).
# Usado para decidir em qual data cai cada refeicao/agua em registros_diarios.
TIMEZONE_PACIENTES=America/Sao_Paulo
