# NutriChat -- variaveis de ambiente para docker-compose.local.yml
# Copie este arquivo para .env e preencha com valores REAIS antes de subir os containers.
#
# > NUNCA commite o .env. NUNCA compartilhe estas chaves em prints, logs ou issues.
#

# =========================================================================
# Postgres local (rede docker interna)
# =========================================================================
POSTGRES_DB=nutrichat
POSTGRES_USER=postgres
POSTGRES_PASSWORD=  # >= 24 chars aleatorios. Ex.: `openssl rand -hex 24`

# =========================================================================
# Supabase Cloud (dados de producao)
# =========================================================================
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# =========================================================================
# Evolution API (WhatsApp)
# =========================================================================
EVOLUTION_API_KEY=  # >= 32 chars. Ex.: `openssl rand -hex 32`
# Secret unico usado no header `X-Webhook-Secret` que a Evolution envia ao backend.
EVOLUTION_WEBHOOK_SECRET=  # `openssl rand -hex 32`

# Origens permitidas no CORS do backend (lista separada por virgula).
# Vazio em dev libera tudo. Em prod obrigatorio: https://SEU_APP.vercel.app
CORS_ORIGIN=

# =========================================================================
# N8N (orquestracao de workflows)
# =========================================================================
N8N_WEBHOOK_URL=http://localhost:5678
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=  # senha forte da UI do N8N

# =========================================================================
# APIs externas de IA
# =========================================================================
CLAUDE_API_KEY=       # https://console.anthropic.com/settings/keys
GROQ_API_KEY=         # https://console.groq.com/keys (Whisper para audios)
OPENAI_API_KEY=       # https://platform.openai.com/api-keys (embeddings RAG)

# =========================================================================
# Chave interna (protege endpoints administrativos: cron, RAG, alertas)
# =========================================================================
INTERNAL_API_KEY=     # `openssl rand -hex 32`
